# Database Configuration
# Если используете Docker Compose, URL должен указывать на имя сервиса 'familytree-db'
# Пример: postgresql://[USER]:[PASSWORD]@familytree-db:5432/[DB_NAME]?schema=public
DATABASE_URL="postgresql://postgres:postgres@familytree-db:5432/familytree?schema=public"

# Database Credentials (для самого контейнера Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=familytree

# NextAuth Configuration
# Генерируется командой: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key"
# Полный URL приложения (обязательно для продакшена)
NEXTAUTH_URL="http://localhost:3000"
